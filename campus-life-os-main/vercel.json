{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend"
    },
    {
      "source": "/((?!frontend).*)",
      "destination": "/frontend/$1"
    }
  ]
}
